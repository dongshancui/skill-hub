{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx", "-y", "@playwright/mcp@latest",
        "--isolated"
      ],
      "enabled": true,
      "timeout": 30000
    },
    "github": {
      "type": "local",
      "command": [
        "npx", "-y", "@modelcontextprotocol/server-github"
      ],
      "enabled": true,
      "timeout": 15000
    }
  }
}

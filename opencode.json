{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "dbhub": {
      "type": "local",
      "command": [
        "powershell", "-NoProfile", "-Command",
        "npx -y @bytebase/dbhub@0.12.1 --transport stdio --dsn $env:MYSQL_DSN"
      ],
      "enabled": false,
      "timeout": 15000
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx", "-y", "@playwright/mcp@latest",
        "--isolated"
      ],
      "enabled": true,
      "timeout": 30000
    },
    "github": {
      "type": "local",
      "command": [
        "npx", "-y", "@modelcontextprotocol/server-github"
      ],
      "enabled": true,
      "timeout": 15000
    }
  }
}
